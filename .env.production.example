DJANGO_SECRET_KEY=ganti-dengan-secret-key-production-yang-panjang-dan-acak
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,domain-anda.com,api.domain-anda.com
DJANGO_CORS_ALLOW_ALL_ORIGINS=0
DJANGO_CORS_ALLOWED_ORIGINS=https://domain-anda.com,https://www.domain-anda.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://domain-anda.com,https://www.domain-anda.com
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1
DJANGO_DB_ENGINE=postgresql
POSTGRES_DB=akademiso
POSTGRES_USER=akademiso
POSTGRES_PASSWORD=ganti-password-postgres-yang-kuat
DJANGO_CREATE_SUPERUSER=0
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=ganti-password-admin-yang-kuat
DJANGO_SUPERUSER_FIRST_NAME=Admin
DJANGO_SUPERUSER_LAST_NAME=Akademiso
DJANGO_LOAD_DEMO_DATA=0
NEXT_PUBLIC_API_URL=https://api.domain-anda.com
GOOGLE_OAUTH_CLIENT_ID=isi-dengan-google-web-client-id
GOOGLE_OAUTH_CLIENT_IDS=isi-dengan-google-web-client-id-atau-daftar-dipisah-koma
NEXT_PUBLIC_GOOGLE_CLIENT_ID=isi-dengan-google-web-client-id
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
